# Override instrument config directory (default: ~/.agentlink/instruments/)
# AGENTLINK_CONFIG_DIR=/path/to/instruments/

# Override pyvisa backend (default: @py for pyvisa-py, pure-Python, no NI-VISA required)
# AGENTLINK_VISA_BACKEND=@ni

# techmanual.ai API key — same variable used by the claude-plugin
# TMAI_API_KEY=your_key_here
